[global_config]
  title_transmit_bg_color = "#241f31"
[keybindings]
[profiles]
  [[default]]
    background_darkness = 0.85
    background_type = transparent
    cursor_color = "#aaaaaa"
    font = Hack Nerd Font 12
    scrollback_infinite = True
    login_shell = True
    use_system_font = False
    background_alpha = 0.1
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
    [[[child1]]]
      type = Terminal
      parent = window0
