{
  "layer": "top",
  "height": 30,
  "modules-left": [
    "custom/menu",
    "sway/workspaces",
    "sway/mode"
  ],
  "modules-center": [
    "sway/window"
  ],
  "modules-right": [
    "network",
    "cpu",
    "memory",
    "battery",
    "temperature",
    "backlight",
    "idle_inhibitor",
    "pulseaudio",
    "custom/pacman",
    "tray",
    "clock"
  ],
