  "clock": {
    "interval": 60,
    "format": "{:%e %b %Y %H:%M}",
    "tooltip": true,
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt>{calendar}</tt>",
    "on-click": "swaymsg exec \\$term_float khal"
  },
  "cpu": {
    "interval": 5,
    "format": "َ°کڑ{usage}%",
    "states": {
