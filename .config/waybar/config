[{
    "layer": "top",
    "position": "bottom",
    "height": 24,
	  "output": "HDMI-A-1",
    "modules-left": ["custom/menu", "sway/workspaces", "sway/mode"],
    "modules-center": [
        "sway/window"
    ],
    "modules-right": [
        "tray",
        "pulseaudio",
        "clock"
    ],

    "custom/menu": {
        "format": "ًںچژ",
        "on-click": "swaymsg exec \\$menu",
        "tooltip": false
    },

    "sway/workspaces": {
        "all-outputs": false,
        "disable-scroll": true,
        "format": "{name}"
    },

    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>",
        "tooltip": false
    },

    "sway/window": {
        "format": "{}",
        "max-length": 120
    },

    "network": {
        "interval": 5,
        "format-wifi": "َ°–© {essid} ({signalStrength}%)", // Icon: wifi
        "format-ethernet": "َ°ˆ€ {ifname}", // Icon: ethernet
        "format-disconnected": "َ±ک–",
        "tooltip-format": "{ifname}: {ipaddr}",
        "on-click": "swaymsg exec \\$shownetwork ifconfig"
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "َ°’³",
            "deactivated": "َ°’²"
        }
    },

    "pulseaudio": {
        //"scroll-step": 1,
        "format": "{icon}{volume}% {format_source}",
        "format-bluetooth": "{icon}َ°‚° {volume}%  َ°چ¬{format_source}",
        "format-muted": "َ°–پ",
        "format-icons": {
            "headphones": "َ°‹‹",
            "handsfree": "َ±‹؟",
            "headset": "َ°‹ژ",
            "phone": "َ°ڈ²",
            "portable": "َ°„‌",
            "car": "َ°„‹",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "swaymsg exec \\$pulseaudio"
    },

    "tray": {
        "icon-size": 21,
        "spacing": 5
    },

    "clock": {
        "interval": 60,
        "format": "{:%A %b %e %H:%M}", // Icon: calendar-alt
        "tooltip": true,
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt>{calendar}</tt>",
        "on-click": "swaymsg exec \\$calendar"
    },
}, {
	  "layer": "top",
	  "position": "bottom",
    "height": 24,
	  "output": "HDMI-A-2",
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "sway/workspaces": {
        "all-outputs": false,
        "disable-scroll": true,
        "format": "{name}"
    },

    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>",
        "tooltip": false
    },

    "sway/window": {
        "format": "{}",
        "max-length": 120
    },
}]
