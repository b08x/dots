    "spacing": 5
  },
  "custom/pacman": {
    "format": "َ°€¼ {}",
    "interval": 3600,
    "exec-if": "[ $(checkupdates | wc -l) -gt 0 ]",
    "exec": "pamac checkupdates | wc -l",
